{
	"name": "productdatabasetogold_salesfact",
	"properties": {
		"folder": {
			"name": "datamapping_medallion"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_ADLS_CSV",
						"type": "LinkedServiceReference"
					},
					"name": "sourceSilver"
				},
				{
					"linkedService": {
						"referenceName": "LS_ADLS_CSV",
						"type": "LinkedServiceReference"
					},
					"name": "sinkFilenames"
				},
				{
					"linkedService": {
						"referenceName": "LS_ADLS_CSV",
						"type": "LinkedServiceReference"
					},
					"name": "sinkProducts"
				},
				{
					"linkedService": {
						"referenceName": "LS_ADLS_CSV",
						"type": "LinkedServiceReference"
					},
					"name": "sinkAddress"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_ADLS_CSV",
						"type": "LinkedServiceReference"
					},
					"name": "sinkSalesFact"
				}
			],
			"transformations": [
				{
					"name": "joinFilenames"
				},
				{
					"name": "joinProducts"
				},
				{
					"name": "joinAddress"
				},
				{
					"name": "selectSalesFact"
				}
			],
			"scriptLines": [
				"source(output(",
				"          OrderID as integer,",
				"          Product as string,",
				"          QuantityOrdered as integer,",
				"          PriceEach as double,",
				"          OrderDate as timestamp,",
				"          PurchaseStreetAddress as string,",
				"          PurchaseCity as string,",
				"          PurchaseState as string,",
				"          PurchaseZipCode as string,",
				"          Filename as string,",
				"          LoadDate as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     fileSystem: 'silver',",
				"     wildcardPaths:['productdatabase']) ~> sourceSilver",
				"source(output(",
				"          Filename as string,",
				"          LoadDate as date,",
				"          FileNameID as long",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     fileSystem: 'gold',",
				"     wildcardPaths:['productdatabase/filenames']) ~> sinkFilenames",
				"source(output(",
				"          Product as string,",
				"          PriceEach as double,",
				"          ProductId as long",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     fileSystem: 'gold',",
				"     wildcardPaths:['productdatabase/product']) ~> sinkProducts",
				"source(output(",
				"          PurchaseStreetAddress as string,",
				"          PurchaseCity as string,",
				"          PurchaseState as string,",
				"          PurchaseZipCode as string,",
				"          PurchaseAddressID as long",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     fileSystem: 'gold',",
				"     wildcardPaths:['productdatabase/purchaseaddress']) ~> sinkAddress",
				"sourceSilver, sinkFilenames join(sourceSilver@Filename == sinkFilenames@Filename",
				"     && sourceSilver@LoadDate == sinkFilenames@LoadDate,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinFilenames",
				"joinFilenames, sinkProducts join(sourceSilver@Product == sinkProducts@Product,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinProducts",
				"joinProducts, sinkAddress join(sourceSilver@PurchaseStreetAddress == sinkAddress@PurchaseStreetAddress",
				"     && sourceSilver@PurchaseCity == sinkAddress@PurchaseCity",
				"     && sourceSilver@PurchaseState == sinkAddress@PurchaseState",
				"     && sourceSilver@PurchaseZipCode == sinkAddress@PurchaseZipCode,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinAddress",
				"joinAddress select(mapColumn(",
				"          OrderID,",
				"          ProductId,",
				"          PurchaseAddressID,",
				"          QuantityOrdered,",
				"          OrderDate,",
				"          FileNameID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectSalesFact",
				"selectSalesFact sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     fileSystem: 'gold',",
				"     folderPath: 'productdatabase/salesfact',",
				"     partitionFileNames:['salesfact.parquet'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sinkSalesFact"
			]
		}
	}
}