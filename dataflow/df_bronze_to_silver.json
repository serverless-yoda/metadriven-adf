{
	"name": "df_bronze_to_silver",
	"properties": {
		"folder": {
			"name": "metadriven_adf_v1"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_ADLS_Dynamic_v1",
						"type": "LinkedServiceReference"
					},
					"name": "bronzesource"
				},
				{
					"linkedService": {
						"referenceName": "LS_ADLS_Dynamic_v1",
						"type": "LinkedServiceReference"
					},
					"name": "silversource"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "joinsilver"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     fileSystem: 'bronze',",
				"     wildcardPaths:['concat($TargetPath, \\'/*.parquet\\')']) ~> bronzesource",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     fileSystem: 'silver',",
				"     wildcardPaths:[(concat($SilverPath, '/*.parquet'))]) ~> silversource",
				"bronzesource, silversource join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinsilver"
			]
		}
	}
}