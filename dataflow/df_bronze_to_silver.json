{
	"name": "df_bronze_to_silver",
	"properties": {
		"folder": {
			"name": "metadriven_adf_v1"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_ADLS_Dynamic_v1",
						"type": "LinkedServiceReference"
					},
					"name": "bronzesource"
				},
				{
					"dataset": {
						"referenceName": "DS_ADLS_Parquet_v1",
						"type": "DatasetReference"
					},
					"name": "silversource"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "exists1"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     fileSystem: 'bronze',",
				"     wildcardPaths:['concat($TargetPath, \\'/*.parquet\\')']) ~> bronzesource",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'parquet',",
				"     wildcardPaths:['*.']) ~> silversource",
				"bronzesource, silversource exists(iif(isNull($LastWatermarkValue), 'recreate', 'none'),",
				"     negate:true,",
				"     broadcast: 'auto')~> exists1"
			]
		}
	}
}