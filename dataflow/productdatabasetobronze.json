{
	"name": "productdatabasetobronze",
	"properties": {
		"description": "this is a use case that create a medallion architecture using data mapping flow",
		"folder": {
			"name": "datamapping_medallion"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"name": "sourceraw"
				}
			],
			"sinks": [
				{
					"name": "productdatabasetobronze"
				}
			],
			"transformations": [
				{
					"name": "addLoadData"
				},
				{
					"name": "renameColumns"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {Order ID} as string,",
				"          Product as string,",
				"          {Quantity Ordered} as string,",
				"          {Price Each} as string,",
				"          {Order Date} as string,",
				"          {Purchase Address} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     rowUrlColumn: 'Filename',",
				"     wildcardPaths:['productdatabase/*.csv'],",
				"     fileSystem: 'raw',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> sourceraw",
				"sourceraw derive(LoadDate = currentDate()) ~> addLoadData",
				"addLoadData select(mapColumn(",
				"          OrderID = {Order ID},",
				"          Product,",
				"          QuantityOrdered = {Quantity Ordered},",
				"          PriceEach = {Price Each},",
				"          OrderDate = {Order Date},",
				"          PurchaseAddress = {Purchase Address},",
				"          Filename,",
				"          LoadDate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> renameColumns",
				"renameColumns sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     truncate: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'parquet',",
				"     fileSystem: 'bronze',",
				"     folderPath: 'productdatabase',",
				"     preCommands: [],",
				"     postCommands: []) ~> productdatabasetobronze"
			]
		}
	}
}