{
	"name": "productdatabasetogold_product",
	"properties": {
		"folder": {
			"name": "datamapping_medallion"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_ADLS_CSV",
						"type": "LinkedServiceReference"
					},
					"name": "sourcesilver"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_ADLS_CSV",
						"type": "LinkedServiceReference"
					},
					"name": "productdimension"
				}
			],
			"transformations": [
				{
					"name": "createProductDimension",
					"description": "Using Aggregate data by 'Product' producing columns 'PriceEach'"
				},
				{
					"name": "surrogateKeyProductId",
					"description": "using SurrogateKey"
				}
			],
			"scriptLines": [
				"source(output(",
				"          OrderID as integer,",
				"          Product as string,",
				"          QuantityOrdered as integer,",
				"          PriceEach as double,",
				"          OrderDate as timestamp,",
				"          PurchaseStreetAddress as string,",
				"          PurchaseCity as string,",
				"          PurchaseState as string,",
				"          PurchaseZipCode as string,",
				"          Filename as string,",
				"          LoadDate as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     fileSystem: 'silver',",
				"     wildcardPaths:['productdatabase']) ~> sourcesilver",
				"sourcesilver aggregate(groupBy(Product),",
				"     PriceEach = last(PriceEach)) ~> createProductDimension",
				"createProductDimension keyGenerate(output(ProductId as long),",
				"     startAt: 1L,",
				"     stepValue: 1L) ~> surrogateKeyProductId",
				"surrogateKeyProductId sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     fileSystem: 'gold',",
				"     folderPath: 'productdatabase/product',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> productdimension"
			]
		}
	}
}